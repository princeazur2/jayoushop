                        <div className="h-10 w-3/4 animate-pulse rounded bg-muted" />
                        <div className="h-8 w-1/3 animate-pulse rounded bg-muted" />
                        <div className="h-24 w-full animate-pulse rounded bg-muted" />
                    </div>
                </div>
            </div>
        );
