                            transition={{ duration: 0.4, delay: 0.3 }}
                            className="font-display mt-6 text-3xl font-medium text-foreground/90"
                        >
                            {product.price.toLocaleString()} FCFA
                        </motion.p>

                        <motion.p
                            initial={{ opacity: 0, y: 20 }}
