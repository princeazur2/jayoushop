                                            <p className="font-display text-xl text-primary font-medium mt-1">{p.price.toLocaleString()} FCFA</p>
                                        </div>
                                    </Link>
                                </motion.div>
                            ))}
                        </div>
                    </div>
                </section>
            )}
        </div>
    );
}
