                            transition={{ duration: 0.4, delay: 0.4 }}
                            className="mt-8 max-w-lg text-base leading-relaxed text-muted-foreground"
                        >
                            {product.description}
                        </motion.p>

                        <motion.div
                            initial={{ opacity: 0, y: 20 }}
